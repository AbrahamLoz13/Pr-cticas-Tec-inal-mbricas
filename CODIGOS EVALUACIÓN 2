import serial
import datetime
from pymongo import MongoClient

# Conexión al motor de base de datos
cliente_mongo = MongoClient("mongodb://localhost:27017/")
db = cliente_mongo["mariscos_el_28"]
coleccion = db["registros_acceso"]

# Configuración de la interfaz serial (Ajustar el puerto COM según corresponda)
puerto_esp32 = serial.Serial('COM3', 115200)

print("Sistema de registro iniciado. Escuchando al ESP32...")

while True:
    if puerto_esp32.in_waiting > 0:
        lectura = puerto_esp32.readline().decode('utf-8').strip()
        
        if lectura == "NUEVO_CLIENTE":
            hora_actual = datetime.datetime.now()
            
            documento = {
                "evento": "llegada_cliente",
                "fecha_hora": hora_actual,
                "sucursal": "Principal"
            }
            
            coleccion.insert_one(documento)
            print(f"Registro guardado exitosamente: {hora_actual}")
